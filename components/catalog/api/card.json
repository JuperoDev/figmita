{
 "name": "Card",
 "category": "Panel",
 "description": "Card is a flexible container component.",
 "docUrl": "https://primevue.org/card/",
 "props": [
  {
   "name": "unstyled",
   "optional": true,
   "type": "boolean",
   "description": "When enabled, it removes component related styles in the core.",
   "default": "false"
  }
 ],
 "events": [],
 "slots": [
  {
   "name": "header",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom header template."
  },
  {
   "name": "title",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom title template."
  },
  {
   "name": "subtitle",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom subtitle template."
  },
  {
   "name": "content",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom content template."
  },
  {
   "name": "footer",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom footer template."
  }
 ],
 "tokens": [
  {
   "name": "--p-card-background",
   "value": "{content.background}"
  },
  {
   "name": "--p-card-border-radius",
   "value": "{border.radius.xl}"
  },
  {
   "name": "--p-card-color",
   "value": "{content.color}"
  },
  {
   "name": "--p-card-shadow",
   "value": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)"
  },
  {
   "name": "--p-card-body-padding",
   "value": "1.25rem"
  },
  {
   "name": "--p-card-body-gap",
   "value": "0.5rem"
  },
  {
   "name": "--p-card-caption-gap",
   "value": "0.5rem"
  },
  {
   "name": "--p-card-title-font-size",
   "value": "1.25rem"
  },
  {
   "name": "--p-card-title-font-weight",
   "value": "500"
  },
  {
   "name": "--p-card-subtitle-color",
   "value": "{text.muted.color}"
  }
 ]
}