{
 "name": "Terminal",
 "category": "Misc",
 "description": "Terminal is a text based user interface.",
 "docUrl": "https://primevue.org/terminal/",
 "props": [
  {
   "name": "welcomeMessage",
   "optional": true,
   "type": "string",
   "description": "Initial text to display on terminal."
  },
  {
   "name": "prompt",
   "optional": true,
   "type": "string",
   "description": "Prompt text for each command."
  },
  {
   "name": "unstyled",
   "optional": true,
   "type": "boolean",
   "description": "When enabled, it removes component related styles in the core.",
   "default": "false"
  }
 ],
 "events": [],
 "slots": [],
 "tokens": [
  {
   "name": "--p-terminal-background",
   "value": "{form.field.background}"
  },
  {
   "name": "--p-terminal-border-color",
   "value": "{form.field.border.color}"
  },
  {
   "name": "--p-terminal-color",
   "value": "{form.field.color}"
  },
  {
   "name": "--p-terminal-height",
   "value": "18rem"
  },
  {
   "name": "--p-terminal-padding",
   "value": "{form.field.padding.y} {form.field.padding.x}"
  },
  {
   "name": "--p-terminal-border-radius",
   "value": "{form.field.border.radius}"
  },
  {
   "name": "--p-terminal-prompt-gap",
   "value": "0.25rem"
  },
  {
   "name": "--p-terminal-command-response-margin",
   "value": "2px 0"
  }
 ]
}