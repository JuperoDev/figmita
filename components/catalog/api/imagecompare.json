{
 "name": "ImageCompare",
 "category": "Media",
 "description": "ImageCompare compares two images side by side with a slider.",
 "docUrl": "https://primevue.org/imagecompare/",
 "props": [
  {
   "name": "tabindex",
   "optional": true,
   "type": "number",
   "description": "Index of the element in tabbing order.",
   "default": "0"
  },
  {
   "name": "ariaLabel",
   "optional": true,
   "type": "string",
   "description": "Defines a string value that labels an interactive element."
  },
  {
   "name": "ariaLabelledby",
   "optional": true,
   "type": "string",
   "description": "Identifier of the underlying input element."
  },
  {
   "name": "unstyled",
   "optional": true,
   "type": "boolean",
   "description": "When enabled, it removes component related styles in the core.",
   "default": "false"
  }
 ],
 "events": [],
 "slots": [
  {
   "name": "left",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom left template."
  },
  {
   "name": "right",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom right template."
  }
 ],
 "tokens": [
  {
   "name": "--p-imagecompare-handle-size",
   "value": "15px"
  },
  {
   "name": "--p-imagecompare-handle-hover-size",
   "value": "30px"
  },
  {
   "name": "--p-imagecompare-handle-background",
   "value": "rgba(255,255,255,0.3)"
  },
  {
   "name": "--p-imagecompare-handle-hover-background",
   "value": "rgba(255,255,255,0.3)"
  },
  {
   "name": "--p-imagecompare-handle-border-color",
   "value": "unset"
  },
  {
   "name": "--p-imagecompare-handle-hover-border-color",
   "value": "unset"
  },
  {
   "name": "--p-imagecompare-handle-border-width",
   "value": "0"
  },
  {
   "name": "--p-imagecompare-handle-border-radius",
   "value": "50%"
  },
  {
   "name": "--p-imagecompare-handle-transition-duration",
   "value": "{transition.duration}"
  },
  {
   "name": "--p-imagecompare-handle-focus-ring-width",
   "value": "{focus.ring.width}"
  },
  {
   "name": "--p-imagecompare-handle-focus-ring-style",
   "value": "{focus.ring.style}"
  },
  {
   "name": "--p-imagecompare-handle-focus-ring-color",
   "value": "rgba(255,255,255,0.3)"
  },
  {
   "name": "--p-imagecompare-handle-focus-ring-offset",
   "value": "{focus.ring.offset}"
  },
  {
   "name": "--p-imagecompare-handle-focus-ring-shadow",
   "value": "{focus.ring.shadow}"
  }
 ]
