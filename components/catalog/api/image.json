   "optional": false,
   "type": "(): void",
   "description": "Triggered when the preview overlay is hidden."
  },
  {
   "name": "error",
   "optional": false,
   "type": "(): void",
   "description": "Triggered when an error occurs while loading an image file."
  }
 ],
