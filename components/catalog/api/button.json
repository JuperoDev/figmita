{
 "name": "Button",
 "category": "Button",
 "description": "Button is an extension to standard button element with icons and theming.",
 "docUrl": "https://primevue.org/button/",
 "extends": "ButtonHTMLAttributes",
 "props": [
  {
   "name": "style",
   "optional": true,
   "type": "any",
   "description": "Inline style of the button."
  },
  {
   "name": "class",
   "optional": true,
   "type": "any",
   "description": "Style class of the button."
  },
  {
   "name": "label",
   "optional": true,
   "type": "string",
   "description": "Text of the button."
  },
  {
   "name": "icon",
   "optional": true,
   "type": "string",
   "description": "Name of the icon."
  },
  {
   "name": "iconPos",
   "optional": true,
   "type": "HintedString<'left' | 'right' | 'top' | 'bottom'>",
   "description": "Position of the icon.",
   "default": "left"
  },
  {
   "name": "iconClass",
   "optional": true,
   "type": "string | object",
   "description": "Style class of the icon."
  },
  {
   "name": "badge",
   "optional": true,
   "type": "string",
   "description": "Value of the badge."
  },
  {
   "name": "badgeClass",
   "optional": true,
   "type": "string | object",
   "description": "Style class of the badge."
  },
  {
   "name": "badgeSeverity",
   "optional": true,
   "type": "HintedString<'secondary' | 'info' | 'success' | 'warn' | 'danger' | 'contrast'> | null",
   "description": "Severity type of the badge."
  },
  {
   "name": "loading",
   "optional": true,
   "type": "boolean",
   "description": "Whether the button is in loading state.",
   "default": "false"
  },
  {
   "name": "loadingIcon",
   "optional": true,
   "type": "string",
   "description": "Icon to display in loading state."
  },
  {
   "name": "as",
   "optional": true,
   "type": "string | Component",
   "description": "Use to change the HTML tag of root element.",
   "default": "BUTTON"
  },
  {
   "name": "asChild",
   "optional": true,
   "type": "boolean",
   "description": "When enabled, it changes the default rendered element for the one passed as a child element.",
   "default": "false"
  },
  {
   "name": "link",
   "optional": true,
   "type": "boolean",
   "description": "Add a link style to the button.",
   "default": "false"
  },
  {
   "name": "severity",
   "optional": true,
   "type": "HintedString<'secondary' | 'success' | 'info' | 'warn' | 'help' | 'danger' | 'contrast'>",
   "description": "Defines the style of the button."
  },
  {
   "name": "raised",
   "optional": true,
   "type": "boolean",
   "description": "Add a shadow to indicate elevation.",
   "default": "false"
  },
  {
   "name": "rounded",
   "optional": true,
   "type": "boolean",
   "description": "Add a circular border radius to the button.",
   "default": "false"
  },
  {
   "name": "text",
   "optional": true,
   "type": "boolean",
   "description": "Add a textual class to the button without a background initially.",
   "default": "false"
  },
  {
   "name": "outlined",
   "optional": true,
   "type": "boolean",
   "description": "Add a border class without a background initially.",
   "default": "false"
  },
  {
   "name": "size",
   "optional": true,
   "type": "HintedString<'small' | 'large'>",
   "description": "Defines the size of the button."
  },
  {
   "name": "variant",
   "optional": true,
   "type": "HintedString<'outlined' | 'text' | 'link'>",
   "description": "Specifies the variant of the component.",
   "default": "undefined"
  },
  {
   "name": "plain",
   "optional": true,
   "type": "boolean",
   "description": "Add a plain textual class to the button without a background initially.",
   "default": "false",
   "deprecated": true
  },
  {
   "name": "fluid",
   "optional": true,
   "type": "boolean",
   "description": "Spans 100% width of the container when enabled.",
   "default": "null"
  },
  {
   "name": "unstyled",
   "optional": true,
   "type": "boolean",
   "description": "When enabled, it removes component related styles in the core.",
   "default": "false"
  }
 ],
 "events": [],
 "slots": [
  {
   "name": "default",
   "optional": false,
   "type": "(scope: { /** * Style class of the button. */ class: string; /** * Object containing the accessibility attributes. * @remarks Only available when {@link ButtonProps.asChild} is set to true. */ a11yAttrs?: Record<string, unknown>; }): VNode[]",
   "description": "Custom content such as icons, images and text can be placed inside the button via the default slot. Note that when slot is used, label, icon and badge properties are not included."
  },
  {
   "name": "icon",
   "optional": false,
   "type": "(scope: { /** * Style class of the icon. */ class: string; }): VNode[]",
   "description": "Custom icon template."
  },
  {
   "name": "loadingicon",
   "optional": false,
   "type": "(scope: { /** * Style class of the loading icon. */ class: string; }): VNode[]",
   "description": "Custom loading icon template."
  }
 ],
