  },
  {
   "name": "icon",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom icon template."
  },
  {
   "name": "removeicon",
   "optional": false,
   "type": "(scope: { /** * Remove icon click event * @param {Event} event - Browser event */ removeCallback: (event: Event) => void; /** * Remove icon keydown event * @param {Event} event - Browser event */ keydownCallback: (event: Event) => void; }): VNode[]",
   "description": "Custom remove icon template of chip component."
  }
 ],
