{
 "name": "Menu",
 "category": "Menu",
 "description": "Menu is a navigation / command component that supports dynamic and static positioning.",
 "docUrl": "https://primevue.org/menu/",
 "props": [
  {
   "name": "model",
   "optional": true,
   "type": "MenuItem[]",
   "description": "An array of menuitems."
  },
  {
   "name": "popup",
   "optional": true,
   "type": "boolean",
   "description": "Defines if menu would displayed as a popup.",
   "default": "false"
  },
  {
   "name": "appendTo",
   "optional": true,
   "type": "HintedString<'body' | 'self'> | undefined | HTMLElement",
   "description": "A valid query selector or an HTMLElement to specify where the overlay gets attached.",
   "default": "body"
  },
  {
   "name": "autoZIndex",
   "optional": true,
   "type": "boolean",
   "description": "Whether to automatically manage layering.",
   "default": "true"
  },
  {
   "name": "baseZIndex",
   "optional": true,
   "type": "number",
   "description": "Base zIndex value to use in layering.",
   "default": "0"
  },
  {
   "name": "tabindex",
   "optional": true,
   "type": "number | string",
   "description": "Index of the element in tabbing order."
  },
  {
   "name": "ariaLabel",
   "optional": true,
   "type": "string",
   "description": "Defines a string value that labels an interactive element."
  },
  {
   "name": "ariaLabelledby",
   "optional": true,
   "type": "string",
   "description": "Identifier of the underlying input element."
  },
  {
   "name": "unstyled",
   "optional": true,
   "type": "boolean",
   "description": "When enabled, it removes component related styles in the core.",
   "default": "false"
  }
 ],
 "events": [
  {
   "name": "focus",
   "optional": false,
   "type": "(event: Event): void",
   "description": "Callback to invoke when the component receives focus."
  },
  {
   "name": "blur",
   "optional": false,
   "type": "(event: Event): void",
   "description": "Callback to invoke when the component loses focus."
  },
  {
   "name": "show",
   "optional": false,
   "type": "(): void",
   "description": "Callback to invoke when the menu popup is shown."
  },
  {
   "name": "hide",
   "optional": false,
   "type": "(): void",
   "description": "Callback to invoke when the menu popup is hidden."
  }
 ],
 "slots": [
  {
   "name": "start",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom start template."
  },
  {
   "name": "end",
   "optional": false,
   "type": "(): VNode[]",
   "description": "Custom end template."
  },
  {
   "name": "item",
   "optional": false,
   "type": "(scope: { /** * Menuitem instance */ item: MenuItem; /** * Label property of the menuitem */ label: string | ((...args: any) => string) | undefined; /** * Binding properties of the menuitem */ props: MenuRouterBindProps; }): VNode[]",
   "description": "Custom item template."
  },
  {
   "name": "itemicon",
   "optional": false,
   "type": "(scope: { /** * Menuitem instance */ item: MenuItem; /** * Style class of the item icon element. */ class: any; }): VNode[]",
   "description": "Custom item icon template."
  },
  {
   "name": "submenuheader",
   "optional": false,
   "type": "(scope: { /** * Menuitem instance */ item: MenuItem; }): VNode[]",
   "description": "Custom submenu header template.",
   "deprecated": true
  },
  {
   "name": "submenulabel",
   "optional": false,
   "type": "(scope: { /** * Menuitem instance */ item: MenuItem; }): VNode[]",
   "description": "Custom submenu label template."
  }
