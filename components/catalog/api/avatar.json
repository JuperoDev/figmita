   "value": "{content.border.radius}"
  },
  {
   "name": "--p-avatar-icon-size",
   "value": "1rem"
  },
  {
   "name": "--p-avatar-group-border-color",
   "value": "{content.background}"
  },
  {
   "name": "--p-avatar-group-offset",
   "value": "-0.75rem"
  },
  {
   "name": "--p-avatar-lg-width",
   "value": "3rem"
  },
  {
   "name": "--p-avatar-lg-height",
   "value": "3rem"
  },
  {
